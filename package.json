{
  "name": "luminalog",
  "displayName": "%displayName%",
  "version": "1.1.0",
  "description": "%description%",
  "categories": [
    "Other"
  ],
  "keywords": [
    "console",
    "log",
    "debug",
    "emoji",
    "typescript",
    "vue",
    "svelte",
    "astro",
    "html",
    "ast",
    "acorn"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lynn1286/luminalog"
  },
  "publisher": "lynn1286",
  "main": "./dist/extension.js",
  "scripts": {
    "clean": "rm -rf dist",
    "commit": "git-cz",
    "compile": "tsc -p tsconfig.json",
    "compile:watch": "tsc -p tsconfig.json --watch",
    "cz": "git-cz",
    "format": "prettier --write \"**/*.{ts,js,json,md}\" \"!node_modules/**\" \"!dist/**\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\" \"!node_modules/**\" \"!dist/**\"",
    "format:pkg": "prettier --write package.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "package": "vsce package",
    "prepare": "husky",
    "pretest": "npm run compile",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "vscode:prepublish": "npm run compile"
  },
  "contributes": {
    "commands": [
      {
        "command": "luminalog.displayLogMessage",
        "title": "%command.displayLogMessage.title%"
      },
      {
        "command": "luminalog.commentAllLogMessages",
        "title": "%command.commentAllLogMessages.title%"
      },
      {
        "command": "luminalog.uncommentAllLogMessages",
        "title": "%command.uncommentAllLogMessages.title%"
      },
      {
        "command": "luminalog.deleteAllLogMessages",
        "title": "%command.deleteAllLogMessages.title%"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "%configuration.title%",
      "properties": {
        "luminalog.wrapLogMessage": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.wrapLogMessage.description%"
        },
        "luminalog.logMessagePrefix": {
          "type": "string",
          "default": "",
          "description": "%configuration.logMessagePrefix.description%"
        },
        "luminalog.randomEmojiPrefix": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.randomEmojiPrefix.description%"
        },
        "luminalog.addSemicolonInTheEnd": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.addSemicolonInTheEnd.description%"
        },
        "luminalog.insertContext": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.insertContext.description%"
        },
        "luminalog.quote": {
          "type": "string",
          "enum": [
            "\"",
            "'"
          ],
          "default": "\"",
          "description": "%configuration.quote.description%"
        },
        "luminalog.makeLogColorful": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.makeLogColorful.description%"
        },
        "luminalog.logMessageFontSize": {
          "type": "number",
          "default": 16,
          "description": "%configuration.logMessageFontSize.description%"
        },
        "luminalog.contextSeparator": {
          "type": "string",
          "default": " -> ",
          "description": "%configuration.contextSeparator.description%"
        },
        "luminalog.customEmojis": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "🔍",
            "🎯",
            "🚀",
            "💡",
            "⚡",
            "🎨",
            "🔥",
            "✨",
            "🎉",
            "🌟"
          ],
          "description": "%configuration.customEmojis.description%"
        },
        "luminalog.customColors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "#FF6B6B",
            "#4ECDC4",
            "#45B7D1",
            "#FFA07A",
            "#98D8C8",
            "#F7DC6F",
            "#BB8FCE",
            "#85C1E2",
            "#F8B739",
            "#52B788"
          ],
          "description": "%configuration.customColors.description%"
        }
      }
    },
    "keybindings": [
      {
        "command": "luminalog.displayLogMessage",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorTextFocus"
      },
      {
        "command": "luminalog.commentAllLogMessages",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c"
      },
      {
        "command": "luminalog.uncommentAllLogMessages",
        "key": "ctrl+alt+u",
        "mac": "cmd+alt+u"
      },
      {
        "command": "luminalog.deleteAllLogMessages",
        "key": "ctrl+alt+d ctrl+alt+l",
        "mac": "cmd+alt+d cmd+alt+l"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "acorn-typescript": "1.4.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vscode/vsce": "^3.7.1",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0",
    "vscode": "^1.109.0"
  },
  "icon": "media/icon.jpg"
}
